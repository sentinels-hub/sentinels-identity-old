        "$type": "color",
        "$description": "Deep navy — the night sky under which sentinels stand watch"
      },
      "secondary": {
        "$value": "#2D6A4F",
        "$type": "color",
        "$description": "Forest green — the ecosystems we protect"
      },
      "accent": {
        "$value": "#E76F51",
        "$type": "color",
        "$description": "Ember orange — the fire we detect before it spreads"
      },
      "surface": {
        "$value": "#F8F9FA",
        "$type": "color",
