      },
      "text-secondary": {
        "$value": "#6B7280",
        "$type": "color",
        "$description": "Slate — supportive, not competing"
      },
      "success": {
        "$value": "#10B981",
        "$type": "color",
        "$description": "Vital green — all clear, the sentinel rests"
      },
      "warning": {
        "$value": "#F59E0B",
        "$type": "color",
        "$description": "Amber alert — attention needed"
      },
      "danger": {
        "$value": "#EF4444",
        "$type": "color",
